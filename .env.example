# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Al Jazeera Telegram Channel Username (without @) or numeric ID
# e.g. aljazeera_english or -1001234567890
ALJAZEERA_CHANNEL_ID=AJENews

# Comma-separated list of group chat IDs where the bot will respond
# Leave empty to allow all groups
ALLOWED_GROUP_IDS=

# Optional: Admin Telegram user ID (bot sends errors/digests here)
ADMIN_USER_ID=
